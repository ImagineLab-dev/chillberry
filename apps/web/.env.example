NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Clave de SITIO de Cloudflare Turnstile (es pública: viaja al navegador).
# Vacía, el widget usa la clave de prueba de Cloudflare, que en desarrollo
# aprueba siempre. En producción NO alcanza con dejarla vacía: la API valida
# contra la clave secreta real y rechaza los tokens de la clave de prueba, así
# que login, registro y pedido público dejan de funcionar.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Dominio raíz, para resolver el subdominio propio de cada restaurante.
# En local se deja vacío: todo va por ruta (/r/<slug>).
NEXT_PUBLIC_ROOT_DOMAIN=

# OJO: Next.js hornea las NEXT_PUBLIC_* en el bundle EN EL MOMENTO DEL BUILD.
# En Docker van como `--build-arg` (ver infra/Dockerfile.web), no como variables
# de entorno del container: si las pasás como env vars, el build ya terminó sin
# ellas y el navegador recibe `undefined`, sin ningún error visible.
