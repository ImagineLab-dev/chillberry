# --- Server ---
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001
LOG_LEVEL=debug

# --- Database (Postgres) ---
DATABASE_URL=postgresql://chillberry:chillberry@localhost:5432/chillberry?schema=public

# --- Redis (cache + colas — usado desde Fase 1) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# CAMBIAR en producción. Generar con `openssl rand -hex 64`
JWT_ACCESS_SECRET=replace-me-with-a-strong-secret-min-32-chars-aaaaaaaaaaaaaaaaaaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-secret-min-32-chars-bbbbbbbbbbbbbbbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Defaults ---
DEFAULT_COUNTRY_CODE=PY
DEFAULT_TIMEZONE=America/Asuncion

# --- CORS ---
WEB_ORIGIN=http://localhost:3000

# --- Pagos (Fase 3) ---
# Secreto compartido para firmar/validar webhooks del proveedor MOCK (sandbox).
MOCK_PROVIDER_SECRET=replace-me-with-a-strong-secret-min-16-chars

# --- SaaS Billing (Fase 6) ---
# Secreto HMAC para firmar/validar webhooks de DLocal. Opcional con default
# de sandbox. CAMBIAR en producción, mismo criterio que MOCK_PROVIDER_SECRET.
DLOCAL_WEBHOOK_SECRET=dev-dlocal-webhook-secret-change-me

# --- WhatsApp / Meta Cloud API (Fase 7) ---
# Ambas opcionales. Sin configurar, WhatsAppAdapter cae en modo sandbox (solo
# loguea, no envía) — configurar ambas activa el envío real vía Meta Cloud API.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Envío de mail (códigos de alta y de recuperación de cuenta) ---
# Sin estas variables el adapter cae en modo sandbox: LOGUEA el mail en vez de
# enviarlo, o sea que nadie puede crear ni recuperar una cuenta. La API avisa al
# arrancar en producción si quedó así.
#
# OJO: son las credenciales de la CASILLA de correo, no la API key del panel de
# hosting. `SMTP_PASSWORD` es la contraseña del buzón soporte@tudominio.
#
# Hostinger: host smtp.hostinger.com, puerto 465 (SSL).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=soporte@chillberry.app
SMTP_PASSWORD=
# Remitente visible. Si se deja vacío se usa SMTP_USER — la mayoría de los
# servidores rechaza enviar con un `from` distinto de la casilla autenticada.
MAIL_FROM=soporte@chillberry.app
MAIL_FROM_NAME=Chillberry

# Fuerza el modo sandbox aunque las credenciales estén puestas. La suite e2e lo
# necesita en `true`: si no, cada corrida manda mails reales a direcciones de
# prueba inexistentes y los rebotes queman la reputación del dominio.
MAIL_SANDBOX=false
