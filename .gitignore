.pnp.js

# Build outputs
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local
# Cualquier variante de entorno queda fuera: `.env.production`, `.env.prod`,
# `.env.staging`... Antes sólo se ignoraban `.env` y `.env.local`, así que un
# `.env.production` con los secretos del servidor se habría subido al repo.
.env.*
!.env.example
!.env.*.example
!.env.*.template

